# Virtual key del LLM Broker de Loggro
# La key real te llega por correo cuando arranca tu ventana de 48h.
# Esta key tiene budget cap pre-configurado para que no te preocupes por costo.
LLM_BROKER_KEY=llm_brk_REPLACE_WITH_YOUR_KEY

# Base URL del broker (OpenAI-compatible API gateway)
# Funciona con litellm, openai SDK, langchain, claude SDK con base_url override.
LLM_BROKER_BASE_URL=https://labs.loggro.com/llm_broker

# Whisper self-hosted (opcional, solo Track D)
# Si preferis no usar STT comercial, podes apuntar aqui.
# WHISPER_SELF_HOSTED_URL=https://labs.loggro.com/whisper

# Tus propias keys (opcional)
# Si preferis usar tus credentials para algun modelo especifico, descomenta y llena.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# ASSEMBLYAI_API_KEY=
