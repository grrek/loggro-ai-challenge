# Virtual key del LLM Broker de Loggro
# La key real te llega por correo cuando arranca tu ventana de 48h.
# Esta key tiene budget cap pre-configurado para que no te preocupes por costo.
LLM_BROKER_KEY=llm_brk_REPLACE_WITH_YOUR_KEY

# Base URL del broker (OpenAI-compatible API gateway)
# Funciona con litellm, openai SDK, langchain, claude SDK con base_url override.
LLM_BROKER_BASE_URL=https://labs.loggro.com/llm_broker

# Whisper self-hosted Loggro Labs (opcional, solo Escenario D)
# Endpoint protegido con Basic Auth. User y password te llegan en el correo de arranque.
# Modelo: small (faster-whisper). Acentos colombianos: razonable. ~40s por minuto de audio en CPU.
# WHISPER_URL=https://labs.loggro.com/whisper
# WHISPER_USER=candidate
# WHISPER_PASSWORD=__te_llega_por_correo__
#
# Ejemplo curl:
#   curl -X POST -u "$WHISPER_USER:$WHISPER_PASSWORD" \
#     -F "audio_file=@data/track-d-intel/audio/call-06-quick-retail-03m04.mp3" \
#     -F "output=json" -F "language=es" \
#     "$WHISPER_URL/asr"
#
# Nota sobre timeouts: el proxy publico puede timear en audios largos (>90s).
# Workarounds:
#   - Usar timeout=600 en tu HTTP client
#   - Chunkear audios largos en partes de ~5 min (con sox o ffmpeg)
#   - O usar Whisper API comercial (OpenAI ~$0.006/min, Deepgram ~$0.0043/min) para audios largos

# Tus propias keys (opcional)
# Si preferis usar tus credentials para algun modelo especifico, descomenta y llena.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# ASSEMBLYAI_API_KEY=
